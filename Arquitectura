<p class="hint-close" id="hint-close" onclick="closeAll()">↑ cerrar detalle</p>

<script>
const panels = ['canales','agente','crm','e1','e2','e3','e4','pipeline','pos','klery'];
let current = null;
function show(id) {
  panels.forEach(p => { var el = document.getElementById('p-'+p); if(el) el.classList.remove('visible'); });
  if (current === id) { current = null; document.getElementById('hint-close').style.display='none'; return; }
  current = id;
  var panel = document.getElementById('p-'+id);
  if (panel) { panel.classList.add('visible'); panel.scrollIntoView({behavior:'smooth',block:'nearest'}); }
  document.getElementById('hint-close').style.display='block';
}
function closeAll() {
  panels.forEach(p => { var el = document.getElementById('p-'+p); if(el) el.classList.remove('visible'); });
  current = null;
  document.getElementById('hint-close').style.display='none';
}
</script>

