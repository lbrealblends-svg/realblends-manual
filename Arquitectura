    .step { display: flex; gap: 10px; align-items: flex-start; font-size: 13px; padding: 6px 0; border-bottom: 0.5px solid #D3D1C7; }
    .step:last-child { border-bottom: none; }
    .step-num { width: 22px; height: 22px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; flex-shrink: 0; margin-top: 1px; }
    .step-text { color: #2C2C2A; line-height: 1.55; }
    .step-sub { color: #888780; font-size: 11px; margin-top: 2px; }
    .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: .5rem; }
    .mini-card { background: #F1EFE8; border-radius: 8px; padding: .75rem; font-size: 12px; }
    .mini-card-label { color: #888780; font-size: 11px; margin-bottom: 3px; }
    .mini-card-val { color: #2C2C2A; font-weight: 500; }
    .hint-close { font-size: 12px; color: #B4B2A9; margin-top: 1rem; cursor: pointer; text-align: right; display: none; }
    .hint-close:hover { color: #888780; }
    .arch-hint { font-size: 12px; color: #B4B2A9; text-align: center; margin-bottom: .5rem; }
    h1 { font-size: 18px; font-weight: 600; color: #2C2C2A; margin-bottom: 4px; }
    .subtitle { font-size: 13px; color: #888780; margin-bottom: 1.25rem; }
